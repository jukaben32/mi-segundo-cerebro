# ═══════════════════════════════════════════════════════════════════════
# ALPACA TRADING BOT - VARIABLES DE ENTORNO
# ═══════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y configura tus credenciales reales
# NUNCA commitees el archivo .env al repositorio
# ═══════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────
# ALPACA API
# ───────────────────────────────────────────────────────────────────────
ALPACA_ENDPOINT=https://paper-api.alpaca.markets
ALPACA_KEY_ID=tu_api_key_aqui
ALPACA_SECRET_KEY=tu_secret_key_aqui

# Para live trading (descomentar cuando estés listo)
# ALPACA_ENDPOINT=https://api.alpaca.markets
# ALPACA_KEY_ID=tu_api_key_live
# ALPACA_SECRET_KEY=tu_secret_key_live

# ───────────────────────────────────────────────────────────────────────
# NOTIFICACIONES - DISCORD
# ───────────────────────────────────────────────────────────────────────
# Generar webhook: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ───────────────────────────────────────────────────────────────────────
# NOTIFICACIONES - SLACK
# ───────────────────────────────────────────────────────────────────────
# Generar webhook: App Settings > Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ───────────────────────────────────────────────────────────────────────
# NOTIFICACIONES - TELEGRAM
# ───────────────────────────────────────────────────────────────────────
# Crear bot con @BotFather y obtener token
# Obtener chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ───────────────────────────────────────────────────────────────────────
# NOTIFICACIONES - EMAIL (SMTP)
# ───────────────────────────────────────────────────────────────────────
# Para Gmail: generar App Password en Account Settings > Security
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password
SMTP_FROM=tu_email@gmail.com
EMAIL_RECIPIENTS=tu_email@gmail.com,otro_email@example.com

# ───────────────────────────────────────────────────────────────────────
# NOTIFICACIONES - PUSHOVER
# ───────────────────────────────────────────────────────────────────────
# Registrar app en https://pushover.net
PUSHOVER_API_TOKEN=your_api_token
PUSHOVER_USER_KEY=your_user_key

# ───────────────────────────────────────────────────────────────────────
# NOTIFICACIONES - TWILIO (SMS)
# ───────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
RECIPIENT_PHONE_NUMBER=+0987654321

# ───────────────────────────────────────────────────────────────────────
# DATOS DE MERCADO (APIs opcionales)
# ───────────────────────────────────────────────────────────────────────
# Polygon.io para datos en tiempo real
POLYGON_API_KEY=your_polygon_key

# Finnhub para news & sentiment
FINNHUB_API_KEY=your_finnhub_key

# TAAPI.io para indicadores técnicos
TAAPI_IO_TOKEN=your_taapi_token

# ───────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN DEL BOT
# ───────────────────────────────────────────────────────────────────────
# Capital inicial (para cálculos de riesgo)
INITIAL_CAPITAL=50000

# Máximo drawdown diario (0.03 = 3%)
MAX_DAILY_DRAWDOWN=0.03

# Máximo drawdown total (0.20 = 20%)
MAX_TOTAL_DRAWDOWN=0.20

# Máximo por posición (0.10 = 10% del portfolio)
MAX_POSITION_PERCENT=0.10

# Intervalo de chequeo en segundos
CHECK_INTERVAL=300

# ───────────────────────────────────────────────────────────────────────
# ESTRATEGIAS
# ───────────────────────────────────────────────────────────────────────
# Habilitar/deshabilitar estrategias
STRATEGY_TRAILING_STOP=true
STRATEGY_COPY_TRADING=false
STRATEGY_WHEEL=true

# Símbolos para trailing stop (separados por coma)
TRAILING_STOP_SYMBOLS=TSLA,NVDA,AMD

# Símbolos para wheel strategy
WHEEL_SYMBOLS=TSLA,AAPL,MSFT

# Político para copy trading
COPY_TRADING_POLITICIAN=Michael McCaul

# ───────────────────────────────────────────────────────────────────────
# DASHBOARD
# ───────────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_DEBUG=false

# ───────────────────────────────────────────────────────────────────────
# LOGGING
# ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/trading_bot.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
